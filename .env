PORT=5005
NODE_ENV=development
VERSION=2.4.0
PASSWORD=change_me
# Set ANONYMOUS_AUTH=true to disable the login wall and treat every visitor as
# authenticated (full view + edit access). Only use behind a trusted reverse
# proxy / private network.
ANONYMOUS_AUTH=true
# When set, the Docker integration auto-discovers tsdproxy-exposed containers:
# tsdproxy.name=myservice -> https://myservice.<TSDPROXY_DOMAIN>. Requires "Use
# Docker API" enabled in Settings > Docker.
# TSDPROXY_DOMAIN=example.ts.net
# Docker discovery creates categorised bookmarks. Containers without a
# flame.category label fall back to this category name.
# DOCKER_DEFAULT_CATEGORY=Apps